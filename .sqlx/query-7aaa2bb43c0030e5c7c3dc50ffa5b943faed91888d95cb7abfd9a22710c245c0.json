  "query": "SELECT \n    a.id,\n    a.name,\n    a.slug,\n    a.category_id,\n    c.name as category_name,\n    c.slug as category_slug,\n    a.icon,\n    a.display_order\nFROM amenities a\nJOIN amenity_categories c ON a.category_id = c.id\nWHERE a.id = ANY($1::uuid[])\nORDER BY c.display_order ASC, a.display_order ASC;\n",
